{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StrategySchema",
  "description": "LLM返回的策略方案——必须经过空模型最终校验",
  "type": "object",
  "required": ["strategy_id", "purpose", "actions", "confidence"],
  "properties": {
    "strategy_id": {
      "type": "string",
      "description": "策略唯一标识"
    },
    "purpose": {
      "type": "string",
      "description": "对应的人类目的"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_type", "target", "parameters"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": ["copy", "move", "delete", "read", "write", "execute", "alert", "recommend"],
            "description": "动作类型"
          },
          "target": {
            "type": "string",
            "description": "动作目标"
          },
          "parameters": {
            "type": "object",
            "description": "动作参数"
          },
          "reasoning": {
            "type": "string",
            "description": "LLM的推理说明"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "LLM对策略的置信度"
    },
    "constraints_checked": {
      "type": "boolean",
      "description": "LLM声称已检查约束（但空模型会独立验证）"
    },
    "fallback": {
      "type": "object",
      "description": "如果主策略失败，LLM建议的降级方案"
    }
  }
}
