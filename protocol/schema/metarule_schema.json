{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetaRuleSchema",
  "description": "隐私资料库中的元规则结构",
  "type": "object",
  "required": ["rule_id", "name", "trigger", "permitted", "forbidden"],
  "properties": {
    "rule_id": {"type": "string"},
    "name": {"type": "string"},
    "trigger": {
      "type": "object",
      "properties": {
        "purposes": {"type": "array", "items": {"type": "string"}},
        "entities": {"type": "array", "items": {"type": "string"}},
        "priority": {"type": "integer", "default": 100}
      }
    },
    "permitted": {
      "type": "object",
      "properties": {
        "extractions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity": {"type": "string"},
              "attributes": {"type": "array", "items": {"type": "string"}},
              "confidence_threshold": {"type": "number", "default": 0.7},
              "retention": {"type": "string", "default": "7_days"},
              "granularity": {"type": "string"},
              "anonymization": {"type": "string"}
            }
          }
        },
        "probes": {"type": "array", "items": {"type": "string"}},
        "models": {"type": "array", "items": {"type": "string"}}
      }
    },
    "forbidden": {
      "type": "object",
      "properties": {
        "extractions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity": {"type": "string"},
              "attributes": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "probes": {"type": "array", "items": {"type": "string"}},
        "models": {"type": "array", "items": {"type": "string"}}
      }
    },
    "alert_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": {"type": "string"},
          "action": {"type": "string"},
          "additional_permitted": {"type": "array"}
        }
      }
    },
    "derived_constraints": {
      "type": "array",
      "items": {"type": "string"},
      "description": "派生约束，如¬Delete(source_file)"
    }
  }
}
