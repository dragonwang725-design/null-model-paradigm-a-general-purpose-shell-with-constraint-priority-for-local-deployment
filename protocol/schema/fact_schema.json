{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FactAtom",
  "description": "事实原子——不可再分的最小观测单元",
  "type": "object",
  "required": ["fact_id", "entity", "attribute", "value", "fact_type", "source"],
  "properties": {
    "fact_id": {
      "type": "string",
      "description": "唯一标识符，如f_cpu_001"
    },
    "entity": {
      "type": "string",
      "description": "实体：cpu, memory, disk, ollama, network, process, system, os, human_shape, video, audio"
    },
    "attribute": {
      "type": "string",
      "description": "属性：usage_percent, free_gb, service_running, version, presence, count"
    },
    "value": {
      "description": "观测值，可以是number/string/boolean/array"
    },
    "fact_type": {
      "type": "string",
      "enum": ["metric", "boolean", "string", "categorical", "event"],
      "description": "值类型"
    },
    "source": {
      "type": "string",
      "description": "数据来源：psutil, ollama_cmd, event_log, probe, derived"
    },
    "raw_text": {
      "type": "string",
      "description": "原始文本（用于LLM输入时保留上下文）"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "观测时间戳"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "感知器置信度"
    }
  }
}
